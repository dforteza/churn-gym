{
  "info": {
    "name": "ChurnGym API - Local",
    "_postman_id": "churngym-api-local-v2",
    "description": "Colección completa ChurnGym API. Ejecutar en orden: Auth → Lanzar → resto.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST-Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Token presente', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
                  "if (json.token) pm.environment.set('jwtToken', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Autentica al usuario admin y guarda el JWT en jwtToken. Ejecutar siempre primero."
          },
          "response": []
        },
        {
          "name": "POST-Login-CredencialesInvalidas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"contraseña_incorrecta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Credenciales incorrectas — debe devolver 401."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Análisis",
      "item": [
        {
          "name": "Lanzar",
          "item": [
            {
              "name": "POST-LanzarAnalisis",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "const json = pm.response.json();",
                      "pm.test('Hay clientes analizados', () => pm.expect(json.totalClientes).to.be.above(0));",
                      "if (json.resultados && json.resultados.content && json.resultados.content.length > 0) {",
                      "    pm.environment.set('clienteId', json.resultados.content[0].clienteId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/analisis/lanzar",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "analisis", "lanzar"]
                },
                "description": "Lanza el motor de riesgo sobre todos los clientes. Guarda el primer clienteId en el entorno."
              },
              "response": []
            },
            {
              "name": "POST-RelanzarAnalisis",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/analisis/lanzar",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "analisis", "lanzar"]
                },
                "description": "Relanza el análisis — borra los resultados anteriores y recalcula. Verifica que calculadoEn se actualiza."
              },
              "response": []
            }
          ]
        },

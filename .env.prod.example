# Plantilla de variables de entorno para PRODUCCIÓN.
# Copia este archivo a ".env" en la VM y rellena los valores reales.
# El .env real NUNCA se sube a git (está en .gitignore).
#
#   cp .env.prod.example .env
#   nano .env

# --- Base de datos ---------------------------------------------------------
POSTGRES_DB=churngym
POSTGRES_USER=churnadmin
# Contraseña fuerte. Genera una con:  openssl rand -base64 24
POSTGRES_PASSWORD=CAMBIAME_password_fuerte

# --- Seguridad JWT ---------------------------------------------------------
# Mínimo 64 caracteres. Genera uno con:  openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CAMBIAME_clave_secreta_de_al_menos_64_caracteres_aleatorios_aqui
JWT_EXPIRATION=86400000

# --- Dominio (para el HTTPS de Caddy) --------------------------------------
# Usa la IP pública de la VM con .nip.io, por ejemplo: 140.238.10.20.nip.io
DOMAIN=CAMBIAME.nip.io
